# Copy to .env.local for `npm run dev`, and set the same values as build-time
# environment variables in Cloudflare Pages.
#
# The anon/publishable key is meant to be public -- every pms_* table has RLS enabled
# with zero policies, so this key can read nothing on its own. Never put the
# service_role key here; it bypasses RLS and belongs only in the Edge Function.

VITE_SUPABASE_URL=https://vhnlvowjqkolpbcbuylr.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_bi03Op6hOscZxuK9qw_7pA_HpFPVVfX
VITE_API_URL=https://vhnlvowjqkolpbcbuylr.supabase.co/functions/v1

# Only set this if you move off the synthetic-email convention (<username>@pms.local).
# It must match PMS_EMAIL_DOMAIN in the Edge Function's secrets.
# VITE_PMS_EMAIL_DOMAIN=pms.local
